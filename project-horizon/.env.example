# ── Database ────────────────────────────────────────────
DB_USER=horizon
DB_PASSWORD=horizon_secret
DB_NAME=horizon
DATABASE_URL=postgresql://horizon:horizon_secret@localhost:5432/horizon

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost

# ── DeepSeek AI (optional) ──────────────────────────────
DEEPSEEK_API_KEY=sk-your-key-here
