# ═══════════════════════════════════════════════════════
# UAID AI — Master Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── AI Engine ──────────────────────────────────────────
# DeepSeek API (required for all AI features)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Knowledge Graph ────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=UAID2026secure!

# ── Vector Database ────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Horizon CRM Database ───────────────────────────────
# SQLite (development)
DATABASE_URL=file:./dev.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://horizon:horizon123@localhost:5432/horizon

# ── Horizon CRM Auth ───────────────────────────────────
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_EXPIRES_IN=7d

# ── Deployment ─────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Open WebUI ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-deepseek-api-key-here
WEBUI_AUTH=false
OPENAI_BASE_URL=https://api.deepseek.com/v1

# ── Docker ─────────────────────────────────────────────
COMPOSE_PROJECT_NAME=uaid-ai